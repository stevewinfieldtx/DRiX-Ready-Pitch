# DRiX-Pitch — Environment Variables

# ─── REQUIRED ──────────────────────────────────────────────────────────────
# Brain reads these too. Pitch consumes the brain, so the brain's env must
# be set here (or in a shared .env at the deployment level).
OPENROUTER_API_KEY=
OPENROUTER_MODEL_ID=anthropic/claude-sonnet-4.5

# ─── PITCH-SPECIFIC ────────────────────────────────────────────────────────
# Port for this app. Brain default is reserved; Ready-Leads-v2 uses 3001;
# Pitch uses 3002 so all three can run side-by-side in dev.
PORT=3002

# Default crawl depth for URL ingestion (customer + solution).
PITCH_CRAWL_DEPTH_DEFAULT=3

# ─── OPTIONAL (brain pass-through) ─────────────────────────────────────────
FIRECRAWL_API_KEY=
APOLLO_API_KEY=
TDE_BASE_URL=https://targeteddecomposition-production.up.railway.app
TDE_API_KEY=
TDE_MIN_ATOMS=15
APP_URL=http://localhost:3002

# ─── BRAIN SERVICE (required for cache lookups) ───────────────────────────
# In local dev: http://localhost:3001
# On Railway: use the internal URL of the drix-brain service
BRAIN_URL=http://localhost:3001
BRAIN_TIMEOUT_MS=10000
